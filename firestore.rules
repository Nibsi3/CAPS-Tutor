/**
 * @file Firestore Security Rules for CAPS Tutor Application
 * @corePhilosophy This ruleset enforces a strict user-ownership model for user-specific data and allows public read access to shared resources like lessons and past papers.
 * @dataStructure Data is organized hierarchically with user-specific data nested under /users/{userId}. Publicly readable data resides in top-level collections.
 * @keySecurityDecisions Users can only manage their own data. Listing of user documents is disallowed for privacy. Past papers are publicly readable.
 * @denormalization User-specific collections are placed under the /users/{userId} path, avoiding the need for get() calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId and the resource exists.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their own document.
     * @allow (get) User with UID 'user123' can get their own document.
     * @allow (update) User with UID 'user123' can update their own document.
     * @allow (delete) User with UID 'user123' can delete their own document.
     * @deny (create) User with UID 'user123' cannot create a document with a different ID ('user456').
     * @deny (get) User with UID 'user123' cannot get the document of another user ('user456').
     * @deny (update) User with UID 'user123' cannot update the document of another user ('user456').
     * @deny (delete) User with UID 'user123' cannot delete the document of another user ('user456').
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users for privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /users/{userId}/studentProgress/{studentProgressId} collection.
     * @path /users/{userId}/studentProgress/{studentProgressId}
     * @allow (create) User with UID 'user123' can create a studentProgress document under their own user document.
     * @allow (get) User with UID 'user123' can get a studentProgress document under their own user document.
     * @allow (update) User with UID 'user123' can update a studentProgress document under their own user document.
     * @allow (delete) User with UID 'user123' can delete a studentProgress document under their own user document.
     * @deny (create) User with UID 'user123' cannot create a studentProgress document under another user's document ('user456').
     * @deny (get) User with UID 'user123' cannot get a studentProgress document under another user's document ('user456').
     * @deny (update) User with UID 'user123' cannot update a studentProgress document under another user's document ('user456').
     * @deny (delete) User with UID 'user123' cannot delete a studentProgress document under another user's document ('user456').
     * @principle Enforces document ownership for all operations on student progress.
     */
    match /users/{userId}/studentProgress/{studentProgressId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /lessons/{lessonId} collection.
     * @path /lessons/{lessonId}
     * @allow (get) Any authenticated user can get a lesson.
     * @allow (list) Any authenticated user can list lessons.
     * @deny (create) No one can create lessons through the client.
     * @deny (update) No one can update lessons through the client.
     * @deny (delete) No one can delete lessons through the client.
     * @principle Lessons are publicly readable but only manageable via backend.
     */
    match /lessons/{lessonId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /lessons/{lessonId}/learningObjectives/{learningObjectiveId} collection.
     * @path /lessons/{lessonId}/learningObjectives/{learningObjectiveId}
     * @allow (get) Any authenticated user can get a learning objective.
     * @allow (list) Any authenticated user can list learning objectives.
     * @deny (create) No one can create learning objectives through the client.
     * @deny (update) No one can update learning objectives through the client.
     * @deny (delete) No one can delete learning objectives through the client.
     * @principle Learning objectives are publicly readable but only manageable via backend.
     */
    match /lessons/{lessonId}/learningObjectives/{learningObjectiveId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /learningObjectives/{learningObjectiveId}/questions/{questionId} collection.
     * @path /learningObjectives/{learningObjectiveId}/questions/{questionId}
     * @allow (get) Any authenticated user can get a question.
     * @allow (list) Any authenticated user can list questions.
     * @deny (create) No one can create questions through the client.
     * @deny (update) No one can update questions through the client.
     * @deny (delete) No one can delete questions through the client.
     * @principle Questions are publicly readable but only manageable via backend.
     */
    match /learningObjectives/{learningObjectiveId}/questions/{questionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /users/{userId}/teacherUploadedSyllabus/{teacherUploadedSyllabusId} collection.
     * @path /users/{userId}/teacherUploadedSyllabus/{teacherUploadedSyllabusId}
     * @allow (create) Teacher with UID 'teacher123' can create a teacherUploadedSyllabus document under their own user document.
     * @allow (get) Teacher with UID 'teacher123' can get a teacherUploadedSyllabus document under their own user document.
     * @allow (update) Teacher with UID 'teacher123' can update a teacherUploadedSyllabus document under their own user document.
     * @allow (delete) Teacher with UID 'teacher123' can delete a teacherUploadedSyllabus document under their own user document.
     * @deny (create) Teacher with UID 'teacher123' cannot create a teacherUploadedSyllabus document under another user's document ('user456').
     * @deny (get) Teacher with UID 'teacher123' cannot get a teacherUploadedSyllabus document under another user's document ('user456').
     * @deny (update) Teacher with UID 'teacher123' cannot update a teacherUploadedSyllabus document under another user's document ('user456').
     * @deny (delete) Teacher with UID 'teacher123' cannot delete a teacherUploadedSyllabus document under another user's document ('user456').
     * @principle Enforces document ownership for all operations on teacher uploaded syllabus.
     */
    match /users/{userId}/teacherUploadedSyllabus/{teacherUploadedSyllabusId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.teacherId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.teacherId == resource.data.teacherId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /pastPapers/{pastPaperId} collection.
     * @path /pastPapers/{pastPaperId}
     * @allow (get) Any authenticated user can get a past paper.
     * @allow (list) Any authenticated user can list past papers.
     * @deny (create) No one can create past papers through the client.
     * @deny (update) No one can update past papers through the client.
     * @deny (delete) No one can delete past papers through the client.
     * @principle Past papers are publicly readable but only manageable via backend.
     */
    match /pastPapers/{pastPaperId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}