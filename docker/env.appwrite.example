# ------------------------------------------------------------------------------
# Appwrite stack - example environment variables for local Docker deployment
# ------------------------------------------------------------------------------
# Copy to `.env.appwrite` in the repo root and customise before starting Docker.
# Secrets below are placeholders – change every value marked `changeme`.
# Official reference: https://appwrite.io/docs/advanced/self-hosting/environment
# ------------------------------------------------------------------------------

# Basic settings
_APP_ENV=production
_APP_EDITION=community
_APP_LOCALE=en
_APP_WORKER_PER_CORE=1

# Domains (use localhost while self-hosting)
_APP_DOMAIN=localhost
_APP_DOMAIN_TARGET=localhost
_APP_DOMAIN_FUNCTIONS=localhost
_APP_CONSOLE_DOMAIN=localhost
_APP_CONSOLE_HOSTNAMES=localhost

# Security + secrets
_APP_OPENSSL_KEY_V1=changeme-openssl-key
_APP_EXECUTOR_SECRET=changeme-executor-secret
_APP_EXECUTOR_HOST=http://openruntimes-executor/v1

# Database
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=appwrite
_APP_DB_PASS=changeme-db-pass
_APP_DB_ROOT_PASS=changeme-root-pass

# Redis
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379
_APP_REDIS_USER=
_APP_REDIS_PASS=

# SMTP (Maildev for local)
_APP_SYSTEM_EMAIL_NAME=CAPS Tutor
_APP_SYSTEM_EMAIL_ADDRESS=team@capstutor.local
_APP_SMTP_HOST=maildev
_APP_SMTP_PORT=1025
_APP_SMTP_SECURE=none
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=

# Storage
_APP_STORAGE_DEVICE=local
_APP_STORAGE_LIMIT=10737418240
_APP_STORAGE_PREVIEW_LIMIT=20971520
_APP_STORAGE_ANTIVIRUS=disabled

# Usage + logging
_APP_USAGE_STATS=enabled
_APP_LOGGING_CONFIG=

# Runtime / functions
_APP_FUNCTIONS_TIMEOUT=900
_APP_FUNCTIONS_BUILD_TIMEOUT=900
_APP_FUNCTIONS_CPUS=1
_APP_FUNCTIONS_MEMORY=2048
_APP_FUNCTIONS_RUNTIMES=node-20.0
_APP_FUNCTIONS_RUNTIMES_NETWORK=runtimes
_APP_OPTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_FUNCTIONS_FORCE_HTTPS=disabled
_APP_OPTIONS_ABUSE=enabled

# Misc
_APP_GRAPHQL_MAX_BATCH_SIZE=50
_APP_GRAPHQL_MAX_COMPLEXITY=6000
_APP_GRAPHQL_MAX_DEPTH=10
_APP_SMS_PROVIDER=mock
_APP_SMS_FROM=CAPS-Tutor
_APP_ASSISTANT_OPENAI_API_KEY=

# Traefik / ports
TRAEFIK_HTTP_PORT=9500
TRAEFIK_HTTPS_PORT=9443
APPWRITE_HTTP_PORT=9501
APPWRITE_REALTIME_PORT=9505
APPWRITE_CONSOLE_PORT=9502

# Docker image tag for Appwrite mono image
APPWRITE_VERSION=1.6.1

