# ------------------------------------------------------------------------------
# CAPS Tutor - Docker runtime environment for the Next.js frontend
# ------------------------------------------------------------------------------
# Copy this file to `.env.docker` in the repo root (kept out of version control)
# and fill in the real secrets before running `docker compose up`.
# ------------------------------------------------------------------------------

# Public values embedded into the browser bundle
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost:9501/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=changeme-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=capstutor

# Server-only Appwrite configuration
APPWRITE_ENDPOINT=http://appwrite/v1
APPWRITE_PROJECT_ID=changeme-project-id
APPWRITE_API_KEY=changeme-super-secret-api-key

# Optional integrations
GROQ_API_KEY=
NEWS_API_KEY=

# Next.js runtime ergonomics
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production

# Resource tuning (optional)
WEB_CPUS=2
WEB_MEM_LIMIT=4g
APPWRITE_CPUS=2
APPWRITE_MEM_LIMIT=4g

# Port that docker publishes (see docker-compose.yml)
PORT=3000
HOSTNAME=0.0.0.0

